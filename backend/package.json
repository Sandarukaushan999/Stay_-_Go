{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node ./node_modules/nodemon/bin/nodemon.js src/server.js",
    "smoke": "node src/smokeTest.js",
    "start": "node src/server.js",
    "seed:maintenance": "node src/seedMaintenance.js",
    "kill": "powershell -Command \"$procs = netstat -ano | Select-String ':5000 ' | Select-String 'LISTENING'; $procs | ForEach-Object { $id = ($_.Line -split '\\s+').Trim()[-1]; if ($id -match '^\\d+$') { taskkill /PID $id /F } }; Write-Host 'Port 5000 cleared'\"",
    "fresh": "npm run kill && npm start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14"
  }
}
