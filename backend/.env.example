# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Client URLs (CORS) ----
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:5174

# ---- MongoDB ----
# For Docker:   mongodb://mongo:27017/stay_go_db
# For local:    mongodb://127.0.0.1:27017/stay_go_db
# For Atlas:    mongodb+srv://user:pass@cluster.mongodb.net/stay_go_db
MONGO_URI=mongodb://127.0.0.1:27017/stay_go_db
MONGO_FALLBACK_URI=mongodb://127.0.0.1:27017/stay_go_db

# ---- Auth ----
JWT_SECRET=your_super_secret_key
JWT_TTL=7d

# ---- External APIs ----
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ---- Safety Monitor ----
SAFETY_CHECKIN_GRACE_MINUTES=5
TRIP_OVERDUE_BUFFER_MINUTES=10

# ---- File Uploads ----
UPLOAD_DIR=uploads
