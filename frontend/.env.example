# Full API root (recommended in dev). Must match where `npm start` listens (see backend PORT, default 5000).
VITE_API_BASE_URL=http://127.0.0.1:5000/api
# If you omit VITE_API_BASE_URL, dev uses http://127.0.0.1:${VITE_API_PORT}/api (default port 5000).
# VITE_API_PORT=5000
VITE_SOCKET_URL=http://127.0.0.1:5000
